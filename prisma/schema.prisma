generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SongStatus {
  READY
  IN_PROGRESS
  WISH
}

enum SetSection {
  SOUNDCHECK
  MAIN
  ENCORE
}

enum MemberRole {
  ADMIN
  MEMBER
  VIEWER
}

// ─── Auth.js models ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  activeBandId  String?

  accounts    Account[]
  sessions    Session[]
  bandMembers BandMember[]

  activeBand Band? @relation("ActiveBand", fields: [activeBandId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Band / multi-tenancy ─────────────────────────────────────────────────────

model Band {
  id   String @id @default(cuid())
  name String

  members       BandMember[]
  songs         Song[]
  setlists      Setlist[]
  venues        Venue[]
  gigs          Gig[]
  activeForUsers User[] @relation("ActiveBand")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BandMember {
  id     String     @id @default(cuid())
  userId String
  bandId String
  role   MemberRole @default(MEMBER)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, bandId])
}

// ─── Domain models ────────────────────────────────────────────────────────────

model Song {
  id               String     @id @default(cuid())
  title            String
  artist           String?
  key              String?
  singer           String?
  status           SongStatus @default(WISH)
  keyboardRequired Boolean    @default(false)
  durationSeconds  Int?
  orientation      String?
  bpm              Int?
  lyricsUrl        String?
  chartsUrl        String?
  bandId           String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  band         Band?         @relation(fields: [bandId], references: [id])
  setlistItems SetlistItem[]
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  address   String?
  notes     String?
  bandId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  band Band?  @relation(fields: [bandId], references: [id])
  gigs Gig[]
}

model Setlist {
  id        String   @id @default(cuid())
  name      String
  bandId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  band  Band?          @relation(fields: [bandId], references: [id])
  items SetlistItem[]
  gig   Gig?
}

model SetlistItem {
  id          String     @id @default(cuid())
  order       Int
  section     SetSection @default(MAIN)
  setNumber   Int        @default(1)
  wasPlayed   Boolean?
  isUnplanned Boolean    @default(false)
  songId      String
  setlistId   String

  song    Song    @relation(fields: [songId], references: [id])
  setlist Setlist @relation(fields: [setlistId], references: [id])
}

model Gig {
  id               String   @id @default(cuid())
  date             DateTime
  notes            String?
  amountContracted Decimal?
  amountPaid       Decimal?
  bandId           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  venueId   String
  setlistId String @unique

  band      Band?         @relation(fields: [bandId], references: [id])
  venue     Venue         @relation(fields: [venueId], references: [id])
  setlist   Setlist       @relation(fields: [setlistId], references: [id])
  expenses  Expense[]
  musicians GigMusician[]
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Decimal
  createdAt   DateTime @default(now())

  gigId String
  gig   Gig    @relation(fields: [gigId], references: [id])
}

model GigMusician {
  id        String   @id @default(cuid())
  name      String
  share     Decimal?
  userId    String?
  createdAt DateTime @default(now())

  gigId String
  gig   Gig    @relation(fields: [gigId], references: [id])
}
